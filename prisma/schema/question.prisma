model Question {
  id            String    @id @default(uuid())
  questionNo    Int       @default(autoincrement()) @map("question_no")
  title         String
  optionA       String    @map("option_a")
  optionB       String    @map("option_b")
  optionC       String    @map("option_c")
  optionD       String    @map("option_d")
  correctAnswer String    @map("correct_answer") @db.VarChar(10)
  explain       String?   @map("explain")
  creatorName   String    @map("creator_name") @db.VarChar(150)
  coachingId    String?   @map("coaching_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  classId       String    @map("class_id")
  topicId       String?   @map("topic_id")
  class         Class     @relation(fields: [classId], references: [id])
  coaching      Coaching? @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  topic         Topic?    @relation(fields: [topicId], references: [id])

  @@map("questions")
}
